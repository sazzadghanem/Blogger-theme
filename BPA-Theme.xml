<body>


<style>
/* HEADER */
.bpa-header{position:fixed;top:0;left:0;width:100%;z-index:1000;padding:15px 0;transition:var(--transition);background:transparent}
.bpa-header.scrolled{background:var(--dark);box-shadow:0 2px 20px rgba(0,0,0,.3)}
.bpa-header .wrapper{display:flex;align-items:center;justify-content:space-between}
.bpa-logo{display:flex;align-items:center;gap:12px}
.bpa-logo img{height:55px;width:55px;border-radius:50%}
.bpa-logo-text{color:var(--white);font-family:var(--heading);font-size:20px;font-weight:700;text-transform:uppercase;line-height:1.2}
.bpa-logo-text span{display:block;font-size:11px;font-weight:400;letter-spacing:2px;color:var(--gold)}
.nav-links{display:flex;align-items:center;gap:30px}
.nav-links a{color:var(--white);font-family:var(--heading);font-size:15px;font-weight:500;text-transform:uppercase;letter-spacing:.5px;position:relative}
.nav-links a:hover{color:var(--gold)}
.nav-links a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:var(--gold);transition:var(--transition)}
.nav-links a:hover::after{width:100%}
.nav-cta .btn{padding:10px 22px;font-size:13px}
.mobile-toggle{display:none;flex-direction:column;gap:5px;cursor:pointer;z-index:1001}
.mobile-toggle span{width:28px;height:3px;background:var(--white);border-radius:2px;transition:var(--transition)}
.mobile-nav{position:fixed;top:0;right:-100%;width:80%;max-width:400px;height:100vh;background:var(--dark);z-index:999;padding:100px 40px 40px;transition:transform .4s ease;display:flex;flex-direction:column}
.mobile-nav.active{right:0;transform:translateX(0)}
.mobile-nav a{display:block;color:var(--white);font-family:var(--heading);font-size:22px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,.1);text-transform:uppercase}
.mobile-nav a:hover{color:var(--gold);padding-left:10px}
.nav-overlay{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.7);z-index:998;opacity:0;visibility:hidden;transition:var(--transition)}
.nav-overlay.active{opacity:1;visibility:visible}

/* HERO SLIDER */
.hero-section{position:relative;height:100vh;min-height:600px;max-height:900px;overflow:hidden}
.hero-slide{position:absolute;top:0;left:0;width:100%;height:100%;opacity:0;transition:opacity 1s ease;background-size:cover;background-position:center}
.hero-slide.active{opacity:1}
.hero-slide::before{content:'';position:absolute;inset:0;background:linear-gradient(to right,rgba(0,0,0,.7) 0%,rgba(0,0,0,.3) 100%)}
.hero-content{position:absolute;top:50%;left:0;transform:translateY(-50%);padding:0 60px;z-index:10;max-width:800px}
.hero-content h1{font-size:clamp(32px,5vw,56px);color:var(--white);margin-bottom:20px;text-transform:uppercase;line-height:1.1}
.hero-content p{font-size:18px;color:rgba(255,255,255,.85);margin-bottom:30px;max-width:550px;line-height:1.7}
.hero-dots{position:absolute;bottom:40px;left:60px;display:flex;gap:12px;z-index:10}
.hero-dot{width:12px;height:12px;border-radius:50%;background:rgba(255,255,255,.4);cursor:pointer;transition:var(--transition)}
.hero-dot.active{background:var(--gold);transform:scale(1.3)}

/* MARQUEE */
.marquee-bar{background:var(--gold);padding:14px 0;overflow:hidden;white-space:nowrap}
.marquee-content{display:inline-block;animation:marquee 20s linear infinite;font-family:var(--heading);font-size:16px;font-weight:600;text-transform:uppercase;color:var(--dark);letter-spacing:1px}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* DISCOVER / SERVICES SECTION */
.discover-section{padding:100px 0 80px}
.discover-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:30px;margin-top:50px}
.discover-card{position:relative;height:550px;overflow:hidden;border-radius:4px;cursor:pointer}
.discover-card .card-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .6s ease}
.discover-card:hover .card-bg{transform:scale(1.05)}
.discover-card::before{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.8) 0%,rgba(0,0,0,.2) 60%);z-index:1}
.discover-card .card-content{position:absolute;bottom:30px;left:25px;right:25px;z-index:2}
.discover-card h3{color:var(--white);font-size:22px;text-transform:uppercase;margin-bottom:8px}
.discover-card p{color:rgba(255,255,255,.8);font-size:15px;line-height:1.5}
.discover-card .card-icon{position:absolute;top:20px;right:20px;z-index:2;width:40px;height:40px;background:var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center}
.discover-card .card-icon i{color:var(--dark);font-size:16px}
</style>


<style>
/* MEDIA HUB / BLOG SECTION */
.media-section{padding:100px 0}
.media-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:50px;flex-wrap:wrap;gap:20px}
.media-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}
.media-card{transition:var(--transition)}
.media-card:hover{transform:translateY(-5px)}
.media-card .card-image{position:relative;padding-bottom:100%;background-size:cover;background-position:center;border-radius:4px;overflow:hidden;margin-bottom:15px}
.media-card .card-image::before{content:'';position:absolute;inset:0;background:rgba(0,0,0,0);transition:var(--transition)}
.media-card:hover .card-image::before{background:rgba(0,0,0,.2)}
.media-card h4{font-size:17px;font-family:var(--heading);line-height:1.4;margin-top:8px}
.media-card:hover h4{color:var(--gold)}

/* VIDEO / ABOUT BLOCK */
.about-block{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:center;padding:80px 0;border-bottom:1px solid rgba(0,0,0,.1)}
.about-block .text-side h2{font-size:clamp(28px,3.5vw,40px);margin-bottom:20px;text-transform:uppercase}
.about-block .text-side p{font-size:16px;color:var(--grey);line-height:1.8;margin-bottom:20px}
.about-block .video-side{position:relative;padding-bottom:56.25%;border-radius:6px;overflow:hidden;background:var(--dark)}
.about-block .video-side iframe{position:absolute;inset:0;width:100%;height:100%;border:none}

/* MEMBERSHIP CTA */
.membership-section{padding:100px 0;display:grid;grid-template-columns:1fr 1fr;gap:0}
.membership-card{position:relative;min-height:500px;display:flex;align-items:flex-end;padding:40px;background-size:cover;background-position:center;overflow:hidden}
.membership-card::before{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.8),rgba(0,0,0,.2))}
.membership-card .card-inner{position:relative;z-index:2}
.membership-card h3{font-size:32px;color:var(--white);text-transform:uppercase;margin-bottom:20px}
.membership-card:last-child{align-items:flex-start;padding-top:60px}
.membership-card:last-child .card-inner{text-align:right;width:100%}

/* COACHING CTA */
.coaching-section{padding:80px 0}
.coaching-block{position:relative;height:550px;overflow:hidden;border-radius:4px}
.coaching-block .coach-bg{position:absolute;inset:0;background-size:cover;background-position:center}
.coaching-block::before{content:'';position:absolute;inset:0;background:linear-gradient(to left,rgba(0,0,0,.8),transparent);z-index:1}
.coaching-block .coach-content{position:absolute;right:60px;top:50%;transform:translateY(-50%);z-index:2;text-align:right}
.coaching-block h3{font-size:36px;color:var(--white);text-transform:uppercase;margin-bottom:20px}

/* EVENTS SECTION */
.events-section{background:var(--light);padding:100px 0}
.events-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:50px;flex-wrap:wrap;gap:20px}
.events-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}
.event-card{transition:var(--transition)}
.event-card:hover{transform:translateY(-5px)}
.event-card .event-image{position:relative;padding-bottom:70%;background:var(--red);background-size:cover;background-position:center;border-radius:4px;overflow:hidden;margin-bottom:15px}
.event-card .event-date{position:absolute;top:10px;left:14px;font-size:28px;font-weight:700;color:var(--white);font-family:var(--heading)}
.event-card h4{font-size:16px;font-family:var(--heading);text-transform:uppercase;letter-spacing:.5px}
.event-card p{font-size:14px;color:var(--grey);margin-top:8px;line-height:1.6}

/* NEWS SECTION */
.news-section{padding:100px 0}
.news-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:50px;flex-wrap:wrap;gap:20px}
.news-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:30px}
.news-card{transition:var(--transition)}
.news-card:hover{transform:translateY(-5px)}
.news-card .news-image{position:relative;padding-bottom:70%;background-size:cover;background-position:center;border-radius:4px;overflow:hidden;margin-bottom:15px}
.news-card .news-image::before{content:'';position:absolute;inset:0;background:rgba(0,0,0,0);transition:var(--transition)}
.news-card:hover .news-image::before{background:rgba(0,0,0,.15)}
.news-card h4{font-size:16px;font-family:var(--heading);text-transform:uppercase;margin-top:8px;line-height:1.4}
.news-card p{font-size:14px;color:var(--grey);margin-top:8px;line-height:1.6}

/* NEWSLETTER */
.newsletter-section{padding:100px 0;background-size:cover;background-position:center;position:relative}
.newsletter-section::before{content:'';position:absolute;inset:0;background:rgba(0,0,0,.75)}
.newsletter-inner{position:relative;z-index:2;max-width:700px}
.newsletter-inner h2{font-size:clamp(28px,4vw,42px);color:var(--white);text-transform:uppercase;margin-bottom:20px}
.newsletter-inner p{color:rgba(255,255,255,.8);font-size:16px;line-height:1.7;margin-bottom:30px}
.newsletter-form{display:flex;gap:12px;max-width:500px}
.newsletter-form input{flex:1;padding:14px 20px;border-radius:3px;font-size:15px;background:var(--white);color:var(--dark)}
.newsletter-form button{white-space:nowrap}
.newsletter-disclaimer{color:rgba(255,255,255,.5);font-size:13px;margin-top:40px;line-height:1.6;max-width:500px}
</style>


<style>
/* FOOTER */
.bpa-footer{background:var(--dark);color:var(--white);padding:80px 0 20px}
.footer-top{display:grid;grid-template-columns:3fr 9fr;gap:50px;align-items:start;margin-bottom:60px}
.footer-logo{display:flex;align-items:center;gap:12px}
.footer-logo img{height:60px;width:60px;border-radius:50%}
.footer-logo-text{font-family:var(--heading);font-size:18px;font-weight:700;text-transform:uppercase;line-height:1.2}
.footer-logo-text span{display:block;font-size:10px;font-weight:400;letter-spacing:2px;color:var(--gold);margin-top:4px}
.footer-links{display:grid;grid-template-columns:repeat(5,1fr);gap:30px}
.footer-links h3{font-family:var(--heading);font-size:14px;color:var(--gold);text-transform:uppercase;margin-bottom:12px;letter-spacing:1px}
.footer-links ul li{margin-bottom:6px}
.footer-links ul li a{font-size:14px;color:rgba(255,255,255,.7);transition:var(--transition)}
.footer-links ul li a:hover{color:var(--gold);padding-left:5px}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;padding-top:20px;border-top:1px solid rgba(255,255,255,.1);flex-wrap:wrap;gap:15px}
.footer-social a{display:inline-block;margin-right:15px;color:rgba(255,255,255,.7);font-size:18px;transition:var(--transition)}
.footer-social a:hover{color:var(--gold);transform:translateY(-2px)}
.footer-copy{font-size:13px;color:rgba(255,255,255,.5)}
.footer-copy a{color:var(--gold)}

/* BLOG POST PAGE */
.post-page{padding:120px 0 80px}
.post-page .post-title{font-size:clamp(28px,4vw,44px);margin-bottom:20px;text-transform:uppercase}
.post-page .post-meta{font-size:14px;color:var(--grey);margin-bottom:30px}
.post-page .post-body{font-size:16px;line-height:1.8;color:#333}
.post-page .post-body img{border-radius:6px;margin:20px 0}
.post-page .post-body h2,.post-page .post-body h3{margin:30px 0 15px;font-family:var(--heading)}
.post-page .post-body p{margin-bottom:16px}
.post-page .post-body a{color:var(--gold);text-decoration:underline}

/* COMMENTS */
.comments-section{padding:40px 0;border-top:1px solid rgba(0,0,0,.1);margin-top:40px}
.comments-section h3{font-size:24px;margin-bottom:20px}
.comment-item{padding:20px 0;border-bottom:1px solid rgba(0,0,0,.06)}
.comment-item .comment-author{font-weight:600;font-size:15px;margin-bottom:4px}
.comment-item .comment-date{font-size:12px;color:var(--grey);margin-bottom:8px}
.comment-item .comment-body{font-size:14px;line-height:1.6}

/* PAGINATION */
.pagination{display:flex;gap:10px;justify-content:center;padding:40px 0}
.pagination a{padding:10px 18px;background:var(--light);border-radius:3px;font-weight:600;font-size:14px;transition:var(--transition)}
.pagination a:hover,.pagination a.active{background:var(--gold);color:var(--dark)}

/* SIDEBAR */
.sidebar-widget{margin-bottom:30px;padding:25px;background:var(--light);border-radius:6px}
.sidebar-widget h3{font-family:var(--heading);font-size:18px;margin-bottom:15px;text-transform:uppercase;padding-bottom:10px;border-bottom:2px solid var(--gold)}
.sidebar-widget ul li{padding:8px 0;border-bottom:1px solid rgba(0,0,0,.06)}
.sidebar-widget ul li a{font-size:14px;color:var(--primary);transition:var(--transition)}
.sidebar-widget ul li a:hover{color:var(--gold);padding-left:5px}

/* RESPONSIVE */
@media(max-width:1024px){
.nav-links{display:none}
.mobile-toggle{display:flex}
.discover-grid{grid-template-columns:repeat(2,1fr)}
.media-grid,.events-grid,.news-grid{grid-template-columns:repeat(2,1fr)}
.membership-section{grid-template-columns:1fr}
.footer-top{grid-template-columns:1fr}
.footer-links{grid-template-columns:repeat(3,1fr)}
.about-block{grid-template-columns:1fr;gap:30px}
.coaching-block{height:400px}
.coaching-block .coach-content{right:30px}
}
@media(max-width:768px){
.hero-section{min-height:500px;max-height:700px}
.hero-content{padding:0 24px}
.hero-content h1{font-size:28px}
.discover-grid{grid-template-columns:1fr}
.discover-card{height:400px}
.media-grid,.events-grid,.news-grid{grid-template-columns:1fr}
.membership-section{padding:60px 0}
.membership-card{min-height:350px;padding:30px}
.footer-links{grid-template-columns:repeat(2,1fr)}
.footer-bottom{flex-direction:column;text-align:center}
.newsletter-form{flex-direction:column}
.coaching-block{height:350px}
.coaching-block .coach-content{position:relative;right:auto;top:auto;transform:none;text-align:left;padding:30px}
.coaching-block::before{background:rgba(0,0,0,.6)}
.events-header,.news-header,.media-header{flex-direction:column;align-items:flex-start}
.hero-dots{left:24px;bottom:24px}
}
@media(max-width:480px){
.wrapper{padding:0 16px}
.bpa-logo img{height:40px;width:40px}
.bpa-logo-text{font-size:16px}
.section-title{font-size:24px}
.footer-links{grid-template-columns:1fr}
.membership-card h3{font-size:24px}
}
</style>


