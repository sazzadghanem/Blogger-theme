<b:skin><![CDATA[
/* === BPA THEME — INSPIRED BY PARKOUR.UK === */
/* Brand: Gold #d4af37 (logo) + Dark #0a0a0a + Bangladesh Red/Green accents */

:root{
  --black:#000000;
  --white:#ffffff;
  --bg:#ffffff;
  --grey:#6b6b6b;
  --grey-light:#f4f4f4;
  --gold:#d4af37;
  --gold-dark:#b8951f;
  --yellow:#d4af37;
  --red:#e63946;
  --blue:#1a1a2e;
  --dark:#0a0a0a;
  --border:rgba(0,0,0,.1);
  --font-body:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;
  --font-button:'Oswald','Bebas Neue',sans-serif;
  --font-heading:'Oswald','Bebas Neue',sans-serif;
}

*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{-webkit-text-size-adjust:100%;scroll-behavior:smooth;overflow-x:hidden}
body{font-family:var(--font-body);font-size:16px;line-height:1.55;color:var(--black);background:var(--bg);overflow-x:hidden;-webkit-font-smoothing:antialiased}
img{max-width:100%;height:auto;display:block}
a{color:inherit;text-decoration:none;transition:color .25s}
ul,ol{list-style:none}
button,input,textarea{font-family:inherit;border:none;outline:none;background:none}
h1,h2,h3,h4,h5,h6{font-family:var(--font-heading);font-weight:600;line-height:1.1;letter-spacing:-.01em;text-transform:uppercase}
.text-3xl{font-size:42px}
.text-4xl{font-size:64px}
.text-2xl{font-size:32px}
.text-xl{font-size:22px}
.text-lg{font-size:17px;line-height:1.6}
.text-sm{font-size:13px}
.text-base{font-size:15px}
.font-button{font-family:var(--font-button);font-weight:500;letter-spacing:.5px}
.font-semibold{font-weight:600}
.uppercase{text-transform:uppercase}
.text-white{color:var(--white)}
.text-black{color:var(--black)}
.text-yellow{color:var(--gold)}
.text-grey{color:var(--grey)}
.bg-black{background:var(--black)}
.bg-white{background:var(--white)}
.bg-blue{background:var(--blue)}
.bg-red{background:var(--red)}
.bg-grey-light{background:var(--grey-light)}
.bg-yellow{background:var(--gold)}

/* === LAYOUT === */
.wrapper{max-width:1440px;margin:0 auto;padding:0 32px}
.wrapper.wider{max-width:1600px}
.full-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:30px}
.full-grid.grid-cols-10{grid-template-columns:repeat(10,1fr)}
.col-span-1{grid-column:span 1}
.col-span-2{grid-column:span 2}
.col-span-3{grid-column:span 3}
.col-span-4{grid-column:span 4}
.col-span-5{grid-column:span 5}
.col-span-6{grid-column:span 6}
.col-span-7{grid-column:span 7}
.col-span-8{grid-column:span 8}
.col-span-9{grid-column:span 9}
.col-span-12,.col-span-full{grid-column:1/-1}
.relative{position:relative}
.absolute{position:absolute}
.fixed{position:fixed}
.block{display:block}
.inline-block{display:inline-block}
.flex{display:flex}
.grid{display:grid}
.items-center{align-items:center}
.text-left{text-align:left}
.text-center{text-align:center}
.text-right{text-align:right}
.text-3xl{font-size:42px}
.cover{background-size:cover;background-position:center;background-repeat:no-repeat}
.center-y{position:absolute;top:50%;left:0;transform:translateY(-50%)}
.w-full{width:100%}
.h-full{height:100%}
.overflow-hidden{overflow:hidden}

/* MARGINS / PADDING utility */
.mt-3{margin-top:12px}.mt-4{margin-top:16px}.mt-6{margin-top:24px}.mt-7{margin-top:28px}.mt-8{margin-top:32px}.mt-10{margin-top:40px}.mt-12{margin-top:48px}.mt-14{margin-top:56px}.mt-16{margin-top:64px}.mt-20{margin-top:80px}.mt-28{margin-top:112px}.mt-32{margin-top:128px}
.mb-2{margin-bottom:8px}.mb-3{margin-bottom:12px}.mb-5{margin-bottom:20px}.mb-6{margin-bottom:24px}.mb-8{margin-bottom:32px}.mb-10{margin-bottom:40px}.mb-12{margin-bottom:48px}.mb-14{margin-bottom:56px}.mb-28{margin-bottom:112px}.mb-32{margin-bottom:128px}
.pt-6{padding-top:24px}.pt-10{padding-top:40px}.pt-14{padding-top:56px}.pt-16{padding-top:64px}.pt-20{padding-top:80px}
.pb-8{padding-bottom:32px}.pb-16{padding-bottom:64px}.pb-20{padding-bottom:80px}
.px-6{padding:0 24px}.px-8{padding:0 32px}.px-24{padding:0 96px}
.py-2{padding:8px 0}.py-3{padding:12px 0}.py-5{padding:20px 0}.py-6{padding:24px 0}
.ml-6{margin-left:24px}.mr-7{margin-right:28px}.mr-4{margin-right:16px}
.max-w-full{max-width:100%}
.min-w-\[600px\]{min-width:600px}
.z-10{z-index:10}.z-20{z-index:20}.z-30{z-index:30}.z-50{z-index:50}.z-\[70\]{z-index:70}.z-\[100\]{z-index:100}

/* === BUTTONS === */
.button{display:inline-block;padding:14px 30px;font-family:var(--font-button);font-size:14px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;border-radius:0;cursor:pointer;transition:all .3s ease;border:2px solid transparent}
.button.yellow{background:var(--gold);color:var(--black)}
.button.yellow:hover{background:var(--gold-dark);transform:translateY(-2px)}
.button.red{background:var(--red);color:var(--white)}
.button.red:hover{background:#c82a37;transform:translateY(-2px)}
.button.white-transparent{background:transparent;border:2px solid var(--white);color:var(--white)}
.button.white-transparent:hover{background:var(--white);color:var(--black)}
.button.black{background:var(--black);color:var(--white)}
.button.black:hover{background:#222}

/* === TAG === */
.tag{display:inline-block;padding:4px 10px;background:var(--gold);color:var(--black);font-size:11px;font-family:var(--font-button);font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-right:6px;margin-bottom:6px}
]]></b:skin>

</head>
<body>

<style>
/* === HEADER === */
.bpa-header{position:fixed;top:0;left:0;width:100%;z-index:90;padding:24px 32px;background:transparent;transition:all .3s ease}
.bpa-header.scrolled{background:rgba(10,10,10,.95);padding:14px 32px;backdrop-filter:blur(10px)}
.bpa-header .full-grid{align-items:center}
.logo-link{display:flex;align-items:center;gap:14px}
.logo-link img{height:50px;width:50px;border-radius:50%;border:2px solid var(--gold)}
.logo-text{font-family:var(--font-heading);font-size:18px;font-weight:700;color:var(--white);text-transform:uppercase;letter-spacing:.5px;line-height:1.1}
.logo-text small{display:block;font-size:9px;font-weight:400;letter-spacing:2px;color:var(--gold);margin-top:3px;text-transform:uppercase}

/* Header social icons (mobile center) */
.header-socials a{display:inline-block;margin:0 6px;color:var(--white);font-size:18px}
.header-socials a:hover{color:var(--gold)}

/* MENU TOGGLE */
.menuToggle{position:relative;width:80px;height:40px;cursor:pointer;display:inline-block;vertical-align:middle}
.menuToggle .menuI{position:absolute;left:0;width:28px;height:2px;background:var(--white);transition:all .3s ease}
.menuToggle .topI{top:14px}
.menuToggle .bottomI{top:22px}
.menuToggle.active .topI{top:18px;transform:rotate(45deg);background:var(--white)}
.menuToggle.active .bottomI{top:18px;transform:rotate(-45deg);background:var(--white)}
.menuText{font-family:var(--font-button);font-size:13px;color:var(--white);letter-spacing:1px;position:absolute;left:36px;top:12px;text-transform:uppercase;font-weight:500}

/* OVERLAY NAV */
.overlayNav{position:fixed;top:0;left:0;width:100%;height:100%;z-index:100;opacity:0;visibility:hidden;transition:all .4s ease}
.overlayNav.active{opacity:1;visibility:visible}
.overlayNav .nav-bg{position:fixed;top:0;right:0;width:60%;height:100%;background-image:url('https://images.unsplash.com/photo-1517836357463-d25dfeac3438?w=1600');background-size:cover;background-position:center;z-index:1}
.overlayNav .navHolder{position:fixed;top:0;left:0;width:50%;min-width:600px;height:100%;background:var(--blue);z-index:20;padding:140px 50px 50px}
.overlayNav .top-bar{position:fixed;top:0;left:0;width:100%;padding:24px 32px;z-index:30;display:flex;justify-content:space-between;align-items:center}
.overlayNav .top-bar .logo-text{color:var(--black)}
.overlayNav .top-bar .menuI{background:var(--black)}
.overlayNav .top-bar .menuText{color:var(--black)}
.navHolder ul li{margin-bottom:6px}
.navLink{display:inline-block;font-family:var(--font-heading);font-size:42px;font-weight:600;color:var(--white);text-transform:uppercase;letter-spacing:-.5px;line-height:1.2;transition:color .25s,padding-left .3s}
.navLink:hover{color:var(--gold);padding-left:10px}
.smallNav{position:absolute;bottom:40px;left:50px;display:flex;gap:14px;align-items:center}
.smallNav a img{width:22px;filter:brightness(0) invert(1)}

/* === HERO TOP SLIDER === */
.topSlider{position:relative;overflow:hidden}
.hero-slide{position:relative;height:770px;width:100%;background-size:cover;background-position:center;display:none}
.hero-slide.active{display:block}
.hero-slide::before{content:'';position:absolute;inset:0;background:linear-gradient(to right,rgba(0,0,0,.55) 0%,rgba(0,0,0,.15) 100%);z-index:1}
.hero-slide .inner{position:absolute;top:50%;left:0;transform:translateY(-50%);padding:0 96px;z-index:5;width:100%}
.hero-slide h1{font-size:56px;color:var(--white);font-family:var(--font-heading);font-weight:600;max-width:860px;margin-bottom:48px;line-height:1.05;text-transform:uppercase;letter-spacing:-.5px}
.slider-dots{position:absolute;bottom:40px;left:96px;display:flex;gap:12px;z-index:10}
.slider-dot{width:50px;height:3px;background:rgba(255,255,255,.4);cursor:pointer;transition:all .3s}
.slider-dot.active{background:var(--gold);height:5px}

/* === DISCOVER SECTION === */
.discover-section{margin-top:80px;padding-bottom:80px}
.discover-section h2{font-size:42px}
.discover-card{position:relative;height:600px;display:block;overflow:hidden}
.discover-card.bg-red{background:var(--red)}
.discover-card.bg-blue{background:var(--blue)}
.discover-card.bg-black{background:var(--black)}
.discover-card .imageHolder{position:absolute;background-size:cover;background-position:center;transition:transform .5s ease}
.discover-card .imageHolder.tl{top:40px;left:40px;right:40px;bottom:40px}
.discover-card .imageHolder.tr{top:0;left:0;right:64px;bottom:97px}
.discover-card .imageHolder.br{bottom:0;right:0;left:64px;top:96px}
.discover-card:hover .imageHolder{transform:scale(1.04)}
.discover-card .textHolder{position:absolute;z-index:10}
.discover-card .textHolder.tl{top:12px;left:20px}
.discover-card .textHolder.bl{bottom:48px;left:20px}
.discover-card .textHolder.bl-mid{bottom:33%;left:20px}
.discover-card h3{color:var(--white);font-size:28px;text-transform:uppercase;line-height:1.1;margin-bottom:24px}
.discover-card .arrow{width:40px;height:40px;display:inline-flex;align-items:center;justify-content:center;color:var(--white);font-size:22px}
.semi-circle{position:absolute;width:227px;left:25%;top:24%;z-index:1;transform:rotate(-12deg);opacity:.15;background:var(--gold);border-radius:50%;height:227px}
.semi-circle-2{position:absolute;width:330px;left:52%;top:45%;z-index:1;background:var(--gold);border-radius:50%;height:330px;opacity:.08}
.discover-text h4{font-family:var(--font-button);text-transform:uppercase;font-size:18px;margin-top:24px;margin-bottom:6px}
.discover-text p{font-size:17px;line-height:1.6;color:#333;max-width:90%}

/* === MARQUEE === */
.marquee{background:var(--gold);padding:18px 0;overflow:hidden;white-space:nowrap;margin:60px 0 0}
.marquee-content{display:inline-block;animation:marquee 30s linear infinite}
.marquee-content span{font-family:var(--font-button);font-size:18px;font-weight:600;color:var(--black);text-transform:uppercase;padding:0 4px;letter-spacing:1px}
@keyframes marquee{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}

/* === MEDIA HUB === */
.media-section{padding:0}
.media-section h2{font-size:42px}
.media-section p{color:#333;font-size:17px;line-height:1.6;max-width:780px;margin-top:24px}
.media-card{display:block;margin-bottom:56px}
.media-card .image{position:relative;background-size:cover;background-position:center;margin-bottom:20px}
.media-card .image::after{content:'';display:block;padding-bottom:100%}
.media-card h4{font-size:21px;margin-top:6px;line-height:1.3;font-family:var(--font-heading);text-transform:none;font-weight:600}
.media-card:hover h4{color:var(--gold)}

/* === BLUE TEXT BLOCK / VIDEO BLOCK === */
.blueTextBlock{align-items:center;border-bottom:1px solid rgba(0,0,0,.15);padding-bottom:0;margin:112px 0}
.standardText h2{font-size:42px;margin-bottom:24px;text-transform:uppercase}
.standardText p{font-size:17px;line-height:1.7;color:#333;white-space:pre-line}
.videoContainer{position:relative;padding-bottom:56.25%;height:0;overflow:hidden}
.videoContainer iframe{position:absolute;inset:0;width:100%;height:100%;border:0}

/* === MEMBERSHIP CTA === */
.membership-cta{margin:112px 0;background-size:cover;background-position:center;display:grid;grid-template-columns:1fr 1fr;gap:30px}
.membership-card{position:relative}
.membership-card::after{content:'';display:block;padding-bottom:100%}
.membership-card.tall::after{padding-bottom:120%}
.membership-card .textWrapper{position:absolute;z-index:10}
.membership-card.left .textWrapper{bottom:26.5%;left:5%}
.membership-card.right .textWrapper{top:26.5%;right:5%;text-align:right}
.membership-card h3{font-size:42px;color:var(--white);text-transform:uppercase;line-height:1;margin-bottom:24px}
.membership-card .bg-img{position:absolute;inset:0;background-size:cover;background-position:center}
.membership-card .bg-img::before{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.7),rgba(0,0,0,.3))}

/* === COACH BLOCK === */
.coach-block{position:relative;height:620px;background:var(--black);overflow:hidden}
.coach-block .imageHolder{position:absolute;left:0;top:64px;right:270px;bottom:0;background-size:cover;background-position:center}
.coach-block .textHolder{position:absolute;top:50%;right:56px;transform:translateY(-50%);z-index:10}
.coach-block h3{font-size:42px;color:var(--white);text-transform:uppercase;line-height:1;margin-bottom:32px}

/* === EVENTS SECTION === */
.events-bg{background:var(--grey-light);margin-top:80px;padding-top:80px;padding-bottom:64px}
.events-bg h2{font-size:42px}
.event-card{display:block;margin-bottom:56px}
.event-card .image{position:relative;background-size:cover;background-position:center;margin-bottom:20px;background:var(--red)}
.event-card .image::after{content:'';display:block;padding-bottom:70%}
.event-card .image .date{position:absolute;top:8px;left:14px;color:var(--white);font-size:32px;font-weight:600;font-family:var(--font-heading)}
.event-card h4{font-size:17px;font-family:var(--font-button);text-transform:uppercase;letter-spacing:.5px;line-height:1.3;font-weight:600}
.event-card p{font-size:15px;color:#333;margin-top:10px;line-height:1.55}

/* === NEWS SECTION === */
.news-section{margin-top:128px;padding-bottom:80px}
.news-section h2{font-size:42px}
.news-card{display:block;margin-bottom:56px}
.news-card .image{position:relative;background-size:cover;background-position:center;margin-bottom:20px}
.news-card .image::after{content:'';display:block;padding-bottom:70%}
.news-card h4{font-size:17px;font-family:var(--font-button);text-transform:uppercase;letter-spacing:.5px;line-height:1.3;margin-top:8px;font-weight:600}
.news-card p{font-size:15px;color:#333;margin-top:10px;line-height:1.55}
</style>


<style>
/* === NEWSLETTER === */
.newsletterHolder{background-size:cover;background-position:center;color:var(--white);position:relative;margin-top:0}
.newsletterHolder::before{content:'';position:absolute;inset:0;background:rgba(0,0,0,.7)}
.newsletterHolder .wrapper{position:relative;z-index:2}
.newsletterHolder h2{font-size:42px;color:var(--white);text-transform:uppercase}
.newsletterHolder p{font-size:17px;line-height:1.6;margin-top:40px;max-width:630px}
.newsletterHolder #signup_form{margin-top:28px}
.newsletterHolder input[type='text'],.newsletterHolder input[type='email']{width:100%;padding:14px 20px;background:var(--white);color:var(--black);border-bottom:1px solid var(--white);border-radius:0}
.newsletterHolder input[type='text']::placeholder,.newsletterHolder input[type='email']::placeholder{color:var(--grey)}
.newsletterHolder .response{color:var(--gold);margin-top:24px;font-size:17px}
.newsletterHolder .privacy-note{font-size:15px;margin-top:112px;max-width:630px;line-height:1.6}

/* === FOOTER === */
.bpa-footer{background:var(--black);color:var(--white);padding:64px 0 16px}
.bpa-footer .footer-top{align-items:center}
.bpa-footer .footer-logo img{max-width:540px;width:100%;border:none;height:auto;border-radius:0}
.bpa-footer .partners{text-align:right}
.bpa-footer .partners img{height:28px;width:auto;display:inline-block;margin-left:24px;margin-bottom:8px;filter:brightness(0) invert(1) opacity(.85)}
.bpa-footer .footerLists{margin-top:112px;display:grid;grid-template-columns:repeat(10,1fr);gap:30px}
.bpa-footer .footerLists>div{grid-column:span 2}
.bpa-footer .footerLists h3{color:var(--gold);font-family:var(--font-button);font-size:13px;text-transform:uppercase;letter-spacing:1px;font-weight:600;margin-bottom:12px}
.bpa-footer .footerLists ul{margin-top:12px;line-height:1.9}
.bpa-footer .footerLists ul li a{font-size:15px;color:var(--white);transition:color .25s,padding-left .25s}
.bpa-footer .footerLists ul li a:hover{color:var(--gold);padding-left:5px}
.bpa-footer .footer-bottom{margin-top:80px;padding-top:24px;border-top:1px solid rgba(255,255,255,.2);display:grid;grid-template-columns:1fr 1fr;align-items:center}
.bpa-footer .footer-bottom .socials a{display:inline-block;margin-right:16px;color:var(--white);font-size:20px}
.bpa-footer .footer-bottom .socials a:hover{color:var(--gold)}
.bpa-footer .footer-bottom .legal{text-align:right;font-size:14px}
.bpa-footer .footer-bottom .legal a{margin-left:32px}
.bpa-footer .footer-bottom .legal a:hover{color:var(--gold)}
.bpa-footer .footer-logo-wrap{display:flex;align-items:center;gap:18px}
.bpa-footer .footer-logo-wrap img{width:80px;height:80px;border-radius:50%;border:2px solid var(--gold)}
.bpa-footer .footer-logo-wrap .text{font-family:var(--font-heading);font-size:24px;font-weight:700;color:var(--white);text-transform:uppercase;line-height:1.1}
.bpa-footer .footer-logo-wrap .text small{display:block;font-size:11px;font-weight:400;letter-spacing:2px;color:var(--gold);margin-top:6px}

/* BLOGGER POST PAGE */
.post-page{padding:140px 0 80px;max-width:900px;margin:0 auto}
.post-page h1.post-title{font-size:48px;margin-bottom:24px;text-transform:uppercase;line-height:1.1}
.post-page .post-meta{font-size:14px;color:var(--grey);margin-bottom:32px;display:flex;gap:20px}
.post-page .post-body{font-size:17px;line-height:1.85;color:#222}
.post-page .post-body p{margin-bottom:18px}
.post-page .post-body img{border-radius:0;margin:24px 0;width:100%;height:auto}
.post-page .post-body a{color:var(--gold);text-decoration:underline}
.post-page .post-body h2,.post-page .post-body h3{margin:36px 0 16px;font-family:var(--font-heading);text-transform:uppercase}
.post-page .post-body blockquote{border-left:4px solid var(--gold);padding:8px 24px;margin:24px 0;font-style:italic;color:#444}
